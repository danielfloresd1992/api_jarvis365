doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(http-equiv="X-UA-Compatible", content="IE=edge")
        meta(name="viewport", content="width=device-width", initial-scale="1.0")
        meta(http-equiv="Expires", content="0")
        meta(http-equiv="Last-Modified", content="0")
        meta(http-equiv="Cache-Control", content="no-cache, mustrevalidate")
        meta(http-equiv="Pragma", content="no-cache")
        title #{tittle}
        link(rel="shortcut icon", href="lobby/img/AppManager.ico" type="image/x-icon")
        link(rel="stylesheet", href="header/header.min.css")
        link(rel="stylesheet", href="Lobby/styles.min.css")
        script(src="/libreries/react/unpkg.com_react@18.2.0_umd_react.production.min.js") 
        script(src="/libreries/react/unpkg.com_react-dom@18.2.0_umd_react-dom.production.min.js") 
        
            
    body 
        nav.heaader#navigator
            
            if  isLoggin === true   
                script(async="true", src="header/index.js" type="module") 
                img.logo-title(src="img/newLogo.svg" draggable="false")

                .searchContain  
                    input.search-input#search-2020(type="text", placeholder="buscar local o usuario")
                    button.search-btn    
                        img.search-btnImg(src="ico/seach/search.svg", alt="")

                div.header-buttonContain
                    #{option}.header-btn#btn-option-admin(data-text="Configuraciones")
                        //img.icoBtnHeader(src="setting/setting.svg")
                        img.icoBtnHeader(src="data:image/png;base64,")
                        div.header-btn-List#btn-option-listContain
                            a.header-btn-List-a(href="/crudLocal") Datos de locales
                            a.header-btn-List-a(href="/crudManager") Listas de gerentes


                    #{home}.header-btn#home(data-text="regresar")
                        img.icoBtnHeader(src="ico/undo/undo.svg")

                    button.header-btn#e-u(data-text="Salir")
                        img.icoBtnHeader(src="ico/logout_FILL0_wght400_GRAD0_opsz48.png", alt="", srcset="")

            else 
                img.logo-title(src="img/newLogo.svg" draggable="false")

                    

            